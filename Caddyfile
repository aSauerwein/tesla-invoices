:9000 {
	root * /data/invoices/

	# issue #8: default the browse listing to newest-modified-first.
	# Caddy's file browser reads ?sort=&order= from the query, so redirect the
	# bare root once to the sorted view. The "not query sort=time" guard stops
	# the redirect from looping on the already-sorted URL.
	@unsorted {
		path /
		not query sort=time
	}
	redir @unsorted "/?sort=time&order=desc"

	file_server browse
}
